# ============================================================
# HHWX 本地 .env.local 示例
# 复制为 .env.local 后，再替换占位值。
# ============================================================

# ------------------------------------------------------------
# 站点公开配置
# 本地开发保持 localhost。
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------
# Supabase：浏览器端 / 鉴权客户端
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# ------------------------------------------------------------
# Supabase：服务端 Service Client
# ------------------------------------------------------------
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
# 仅当服务端地址与 NEXT_PUBLIC_SUPABASE_URL 不同时才需要。
# SUPABASE_URL=https://your-project.supabase.co

# ------------------------------------------------------------
# Cloudflare Turnstile
# 可选。本地不启用时可留空。
# ------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------
# Bandori 资源 CDN
# 本地开发仍然直连生产 CDN 域名。
# ------------------------------------------------------------
NEXT_PUBLIC_BANDORI_ASSET_CDN_BASE_URL=https://cdn.hhwx.org
BANDORI_ASSET_CDN_BASE_URL=https://cdn.hhwx.org