# ============================================================
# HHWX Web environment template
# Copy to .env.local for local development; set the same values in the deployment platform for production.
# ============================================================

# ------------------------------------------------------------
# Public site settings
# These values are exposed to browsers.
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://your-hhwx-site.example.com
# Preview deployments are usually injected by the platform.
# NEXT_PUBLIC_VERCEL_URL=your-preview-hostname.vercel.app

# ------------------------------------------------------------
# Supabase: browser client
# Required.
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# ------------------------------------------------------------
# Supabase: server-side service client
# Required for server-side reads/writes.
# ------------------------------------------------------------
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
# Optional. Only set this when the server-side Supabase URL differs from NEXT_PUBLIC_SUPABASE_URL.
# SUPABASE_URL=https://your-project.supabase.co

# ------------------------------------------------------------
# Cloudflare Turnstile
# Optional. Leave both empty to disable Turnstile.
# ------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------
# HHWX site asset CDN
# Static site/game assets should be served from your own asset host.
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_ASSET_CDN_BASE_URL=https://your-site-asset-cdn.example.com

# ------------------------------------------------------------
# Bandori asset CDN
# Optional for public asset-heavy pages. This repo defines the URL contract,
# but does not include HHWX production's private ingestion/mirroring service.
# These two values are usually the same.
# ------------------------------------------------------------
NEXT_PUBLIC_BANDORI_ASSET_CDN_BASE_URL=https://your-bandori-asset-cdn.example.com
BANDORI_ASSET_CDN_BASE_URL=https://your-bandori-asset-cdn.example.com

# ------------------------------------------------------------
# Bandori master artifacts
# Server-side only. hhwx-tracker publishes these JSON artifacts.
# Artifact mode serves most public master datasets from HHWX artifacts.
# While the artifact builder is catching up, cards.skillId is temporarily
# normalized from Bestdori-compatible IDs so team-builder scoring stays correct.
# ------------------------------------------------------------
BANDORI_MASTER_SOURCE=bestdori
# Comma-separated server order for artifact mode. Payloads are merged into one
# Bestdori-style response with regional arrays, not exposed as per-server URLs.
# Use BANDORI_MASTER_ARTIFACT_SERVER as the single-server fallback.
# BANDORI_MASTER_ARTIFACT_SERVERS=jp,cn
BANDORI_MASTER_ARTIFACT_SERVER=cn
# Object-storage active manifest entry. Example:
# BANDORI_MASTER_ARTIFACT_BASE_URL=https://cdn.hhwx.org/bandori/master
# Supabase active pointer mode also needs a public origin for manifest/artifact paths.
# BANDORI_MASTER_ACTIVE_SOURCE=object-storage
# BANDORI_MASTER_ARTIFACT_PUBLIC_ORIGIN=https://cdn.hhwx.org
# BANDORI_MASTER_ARTIFACT_MANIFEST_URL=https://cdn.hhwx.org/bandori/master/{server}/active/manifest.json
#
# Production can bypass the public CDN and read master artifacts from R2 directly.
# Keep these values server-side only; never prefix them with NEXT_PUBLIC_.
# BANDORI_MASTER_ARTIFACT_READ_MODE=r2
# BANDORI_MASTER_ARTIFACT_PREFIX=bandori/master
# BANDORI_MASTER_R2_ACCOUNT_ID=your_cloudflare_account_id
# Or set BANDORI_MASTER_R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
# BANDORI_MASTER_R2_BUCKET=your_r2_bucket
# BANDORI_MASTER_R2_ACCESS_KEY_ID=your_r2_access_key_id
# BANDORI_MASTER_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# BANDORI_MASTER_R2_REGION=auto
# For shared private deployments, these may also be supplied as BANDORI_R2_*.

# ------------------------------------------------------------
# HHWX user fetcher service for game-account binding verification and manual game data sync.
# Private compatible service. This repo does not include an implementation.
# Leave empty unless you operate your own compatible endpoint.
# Server-side only. Do not prefix with NEXT_PUBLIC_.
# ------------------------------------------------------------
HHWX_USER_FETCHER_BASE_URL=
HHWX_USER_FETCHER_TOKEN=
