# ============================================================
# HHWX Web environment template
# Copy to .env.local for local development; set the same values in the deployment platform for production.
# ============================================================

# ------------------------------------------------------------
# Public site settings
# These values are exposed to browsers.
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://your-hhwx-site.example.com
# Preview deployments are usually injected by the platform.
# NEXT_PUBLIC_VERCEL_URL=your-preview-hostname.vercel.app

# ------------------------------------------------------------
# Supabase: browser client
# Required.
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# ------------------------------------------------------------
# Supabase: server-side service client
# Required for server-side reads/writes.
# ------------------------------------------------------------
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
# Optional. Only set this when the server-side Supabase URL differs from NEXT_PUBLIC_SUPABASE_URL.
# SUPABASE_URL=https://your-project.supabase.co

# ------------------------------------------------------------
# Cloudflare Turnstile
# Optional. Leave both empty to disable Turnstile.
# ------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------
# HHWX site asset CDN
# Static site/game assets should be served from your own asset host.
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_ASSET_CDN_BASE_URL=https://your-site-asset-cdn.example.com

# ------------------------------------------------------------
# Bandori asset CDN
# Optional for public asset-heavy pages. This repo defines the URL contract,
# but does not include HHWX production's private ingestion/mirroring service.
# These two values are usually the same.
# ------------------------------------------------------------
NEXT_PUBLIC_BANDORI_ASSET_CDN_BASE_URL=https://your-bandori-asset-cdn.example.com
BANDORI_ASSET_CDN_BASE_URL=https://your-bandori-asset-cdn.example.com

# ------------------------------------------------------------
# HHWX user fetcher service for game-account binding verification and manual game data sync.
# Private compatible service. This repo does not include an implementation.
# Leave empty unless you operate your own compatible endpoint.
# Server-side only. Do not prefix with NEXT_PUBLIC_.
# ------------------------------------------------------------
HHWX_USER_FETCHER_BASE_URL=
HHWX_USER_FETCHER_TOKEN=
